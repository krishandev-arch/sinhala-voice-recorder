# ─── DATABASE ─────────────────────────────────────────────────
# MySQL connection string (used by Drizzle ORM, seed script, and server)
# Format: mysql://username:password@host:port/database_name
DATABASE_URL=mysql://root:Absolx@26Jay@localhost:3306/sinhala_voice_recorder

# ─── AUTHENTICATION (Manus OAuth) ────────────────────────────
# JWT secret for signing session cookies
JWT_SECRET=your-jwt-secret-key-here-min-32-chars

# OAuth server URL for Manus authentication
OAUTH_SERVER_URL=https://oauth.manus.app

# Owner's OpenID - this user gets auto-assigned admin role
OWNER_OPEN_ID=your-manus-open-id

# ─── CLOUD STORAGE (S3 via Forge) ────────────────────────────
# Forge API URL for S3 presigned URL generation (audio file upload/download)
BUILT_IN_FORGE_API_URL=https://forge-api.manus.app

# Forge API key for authentication with storage service
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# ─── CLIENT-SIDE (VITE_ prefix = exposed to browser) ─────────
# Application ID for OAuth flow
VITE_APP_ID=your-app-id

# OAuth portal URL for login redirect
VITE_OAUTH_PORTAL_URL=https://oauth.manus.app

# (Optional) Frontend Forge API credentials for Map component
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ─── SERVER ───────────────────────────────────────────────────
# Server port (default: 3000)
PORT=3000

# Node environment: development | production
NODE_ENV=development
DATABASE_URL=mysql://root:root@127.0.0.1:3306/sinhala_voice
DEV_BYPASS_AUTH=true
DEV_BYPASS_ROLE=admin
DEV_BYPASS_NAME=Local Dev
DEV_BYPASS_OPEN_ID=dev-local-user


